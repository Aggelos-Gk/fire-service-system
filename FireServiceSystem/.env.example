# Supabase Postgres (do not commit your real .env)
# Example (format): jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require
# Alternative (single var): DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
SUPABASE_DB_JDBC_URL=
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=

# Optional (dev only): validate | update | create | create-drop
HIBERNATE_DDL_AUTO=validate

# Backend CORS allow-list (comma-separated, no spaces)
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend API base URL
REACT_APP_API_BASE_URL=http://localhost:8080
